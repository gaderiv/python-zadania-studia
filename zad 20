import math
import random

a = float(input('Wprowadź pierwszą liczbę: '))
b = float(input('Wprowadź drugą liczbę: '))
wybor = input('wpisz odpowiednia liczbe przypisana obok metody \n1. dodawanie \n2. odejmowanie \n3. mnozenie \n4. dzielenie: ')


if wybor == '1':
    wynik = a + b
    print(wynik)
elif wybor == '2':
    wynik = a - b
    print(wynik)
elif wybor =='3':
    wynik = a * b
    print(wynik)
elif wybor == '4':
    try:
        wynik = a / b
        print(wynik)
    except ZeroDivisionError as p:
        print('Wystąpił błąd:', p)
        
